;;; route_nets EU  —  Cadence Virtuoso Apply EU (Five-Phase Write Protocol, Phase 5)
;;; Reads the binary delta file and applies shape changes to the live OA database
;;; inside a single undoable group.
;;; ─────────────────────────────────────────────────────────────────────────
;;; Jinja2 template variables:
;;;   delta_path     : string — path to the binary delta file on /eda_share
;;;   undo_group     : string — unique name for the undo group (e.g. "eda_route_001")
;;;   timeout_s      : int    — abort if Apply takes longer than this (safety)

let( (cv deltaPath undoGroupName parser rec layer purpose x y w h shapes)
  setq(cv geGetWindowCellView())
  unless(cv error("route_nets EU: No active cellview"))

  setq(deltaPath    "{{ delta_path }}")
  setq(undoGroupName "{{ undo_group }}")

  ; ── Pre-flight: check file exists ─────────────────────────────────────────
  unless(isFile(deltaPath)
    error("route_nets EU: Delta file not found: %s" deltaPath))

  ; ── Open undo group ───────────────────────────────────────────────────────
  dbOpenUndoGroup(cv undoGroupName)

  ; ── Parse binary delta (EDAB format) and apply shapes ────────────────────
  ; NOTE: A pure-SKILL binary parser for the EDAB format would be implemented
  ; here.  For the initial version we use a helper Python script that converts
  ; the binary delta to a SKILL-readable ASCII format, then apply that.
  ; Full binary parser is deferred to Phase 2 implementation.
  let( (asciiPath fp line parts opcode)
    setq(asciiPath strcat(deltaPath ".skill_ascii"))
    ; Convert delta to ASCII using the helper (run externally before EU execution)
    unless(isFile(asciiPath)
      error("route_nets EU: ASCII delta not found: %s" asciiPath))

    setq(fp infile(asciiPath))
    setq(line readLine(fp))
    while(line
      setq(parts parseString(line " "))
      setq(opcode nth(0 parts))
      cond(
        (equal(opcode "ADD_RECT")
          ; ADD_RECT <layer> <purpose> <x> <y> <w> <h>
          dbCreateRect(cv
            list(atoi(nth(1 parts)) atoi(nth(2 parts)))
            list(atoi(nth(3 parts)):atoi(nth(4 parts))
                 (atoi(nth(3 parts)) + atoi(nth(5 parts))):(atoi(nth(4 parts)) + atoi(nth(6 parts)))))
        )
        (equal(opcode "DEL_RECT")
          ; Deletion: find and delete matching shape
          ; (simplified — full implementation uses shape ID tracking)
          printf("route_nets EU: DEL_RECT not yet implemented\n")
        )
        (equal(opcode "ADD_VIA")
          ; ADD_VIA <x> <y> <via_def_idx>
          let( (viaName)
            setq(viaName nth(atoi(nth(3 parts)) (list {% for v in via_def_names %}"{{ v }}"{% if not loop.last %} {% endif %}{% endfor %})))
            when(viaName
              dbCreateVia(cv viaName
                atoi(nth(1 parts)):atoi(nth(2 parts)) "R0"))
          )
        )
      )
      setq(line readLine(fp))
    )
    close(fp)
  )

  ; ── Close undo group ──────────────────────────────────────────────────────
  dbCloseUndoGroup(cv undoGroupName)
  dbSave(cv)

  printf("route_nets EU: Applied delta from %s\n" deltaPath)
  "ok"
)
